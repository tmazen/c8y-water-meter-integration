{
  "apiVersion": "2",
  "version": "1.0.3",
  "provider": {
    "name": "Cumulocity"
  },
  "isolation": "PER_TENANT",
  "replicas": 1,
  "contextPath": "c8y-oms-parser",
  "resources": {
    "memory": "512Mi",
    "cpu": "0.5"
  },
  "livenessProbe": {
    "httpGet": {
      "path": "/health",
      "port": 80
    },
    "initialDelaySeconds": 30,
    "periodSeconds": 10,
    "failureThreshold": 3
  },
  "readinessProbe": {
    "httpGet": {
      "path": "/health",
      "port": 80
    },
    "initialDelaySeconds": 20,
    "periodSeconds": 10,
    "failureThreshold": 3
  },
  "requiredRoles": [
    "ROLE_INVENTORY_READ"
  ],
  "roles": []
}
